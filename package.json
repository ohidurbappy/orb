{
  "name": "orb",
  "version": "0.1.0",
  "description": "A growable cross-platform CLI toolbox",
  "type": "module",
  "bin": {
    "orb": "./src/cli.tsx"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "start": "bun run src/cli.tsx",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ohidurbappy/orb.git"
  },
  "dependencies": {
    "env-paths": "^3.0.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/semver": "^7.5.8",
    "bun-types": "^1.3.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
